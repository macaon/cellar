    "--share=network",
    "--share=ipc",
    "--socket=wayland",
    "--socket=x11",
    "--socket=pulseaudio",
    "--socket=ssh-auth",
    "--filesystem=home",
    "--device=all",
    "--allow=multiarch",
    "--talk-name=org.freedesktop.secrets",
    "--talk-name=org.kde.kwalletd5",
    "--talk-name=org.kde.kwalletd6",
    "--talk-name=org.freedesktop.Flatpak"
